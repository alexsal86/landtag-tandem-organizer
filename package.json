{
  "name": "landtagsos",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "lint": "eslint . --report-unused-disable-directives",
    "preview": "vite preview",
    "test:role-smoke": "node scripts/mywork-role-smoke-test.mjs",
    "check:diagram-drift": "node scripts/check-diagram-drift.mjs",
    "lint:knowledge": "eslint src/components/KnowledgeBaseView.tsx src/hooks/useKnowledgeDocumentTopics.tsx src/hooks/useTopics.tsx --max-warnings 0",
    "typecheck:baseline-global": "tsc -p tsconfig.app.json --noEmit",
    "typecheck:legacy-exceptions": "npm run typecheck:hooks-batch1 && npm run typecheck:contexts && npm run typecheck:services-features && npm run typecheck:components-batch1 && npm run typecheck:components-batch2 && npm run typecheck:components-batch3 && npm run typecheck:components-batch4 && npm run typecheck:components-toplevel && npm run typecheck:pages",
    "typecheck:batch-governed": "npm run typecheck:flow-auth-tenant && npm run typecheck:flow-calendar-sync && npm run typecheck:flow-letter-workflow && npm run typecheck:flow-notifications && npm run typecheck:flow-edge-auth-role-tenant && npm run typecheck:knowledge && npm run typecheck:auth && npm run typecheck:quicknotes && npm run typecheck:notifications && npm run typecheck:dashboard && npm run typecheck:utils && npm run typecheck:hooks-batch2 && npm run typecheck:hooks-batch3 && npm run typecheck:services-features-batch2 && npm run typecheck:services-features-batch3 && npm run typecheck:pages-batch2 && npm run typecheck:pages-batch3",
    "typecheck:knowledge": "tsc -p tsconfig.knowledge-strict.json --noEmit",
    "typecheck:auth": "tsc -p tsconfig.auth-strict.json --noEmit",
    "typecheck:flow-auth-tenant": "tsc -p tsconfig.flow-auth-tenant-strict.json --noEmit",
    "typecheck:flow-calendar-sync": "tsc -p tsconfig.flow-calendar-sync-strict.json --noEmit",
    "typecheck:flow-letter-workflow": "tsc -p tsconfig.flow-letter-workflow-strict.json --noEmit",
    "typecheck:flow-notifications": "tsc -p tsconfig.flow-notifications-strict.json --noEmit",
    "typecheck:flow-edge-auth-role-tenant": "tsc -p tsconfig.flow-edge-auth-role-tenant-strict.json --noEmit",
    "typecheck:quicknotes": "tsc -p tsconfig.quicknotes-strict.json --noEmit",
    "typecheck:notifications": "tsc -p tsconfig.notifications-strict.json --noEmit",
    "typecheck:dashboard": "tsc -p tsconfig.dashboard-strict.json --noEmit",
    "typecheck:utils": "tsc -p tsconfig.strict-utils.json --noEmit",
    "typecheck:hooks-batch1": "tsc -p tsconfig.hooks-batch1-strict.json --noEmit",
    "typecheck:hooks-batch2": "tsc -p tsconfig.hooks-batch2-strict.json --noEmit",
    "typecheck:hooks-batch3": "tsc -p tsconfig.hooks-batch3-strict.json --noEmit",
    "typecheck:contexts": "tsc -p tsconfig.contexts-strict.json --noEmit",
    "typecheck:services-features": "tsc -p tsconfig.services-features-strict.json --noEmit",
    "typecheck:services-features-batch2": "tsc -p tsconfig.services-features-batch2-strict.json --noEmit",
    "typecheck:services-features-batch3": "tsc -p tsconfig.services-features-batch3-strict.json --noEmit",
    "typecheck:components-batch1": "tsc -p tsconfig.components-batch1-strict.json --noEmit",
    "typecheck:components-batch2": "tsc -p tsconfig.components-batch2-strict.json --noEmit",
    "typecheck:components-batch3": "tsc -p tsconfig.components-batch3-strict.json --noEmit",
    "typecheck:components-batch4": "tsc -p tsconfig.components-batch4-strict.json --noEmit",
    "typecheck:components-toplevel": "tsc -p tsconfig.components-toplevel-strict.json --noEmit",
    "typecheck:pages": "tsc -p tsconfig.pages-strict.json --noEmit",
    "typecheck:pages-batch2": "tsc -p tsconfig.pages-batch2-strict.json --noEmit",
    "typecheck:pages-batch3": "tsc -p tsconfig.pages-batch3-strict.json --noEmit",
    "typecheck:strict-all": "npm run typecheck:baseline-global && npm run typecheck:batch-governed && npm run typecheck:legacy-exceptions",
    "report:bundle-size": "node scripts/report-bundle-size.mjs",
    "check:security-doc-drift": "node scripts/check-security-doc-drift.mjs",
    "check:dangerouslysetinnerhtml-inventory": "node scripts/check-dangerouslysetinnerhtml-inventory.mjs",
    "check:security-hygiene": "npm run check:security-doc-drift && npm run check:dangerouslysetinnerhtml-inventory && npm run check:edge-function-security",
    "test:unit-integration:ci": "vitest run --reporter=dot --passWithNoTests",
    "test:coverage:ci": "vitest run --coverage.enabled=true --coverage.provider=v8 --coverage.reporter=json-summary --coverage.reporter=text --coverage.reportsDirectory=coverage --passWithNoTests",
    "coverage:thresholds:warn": "node scripts/check-coverage-thresholds.mjs --mode=warn",
    "coverage:thresholds:block": "node scripts/check-coverage-thresholds.mjs --mode=block",
    "check:edge-function-security": "node scripts/check-edge-function-security.mjs",
    "test:e2e-smoke": "npm run test:role-smoke && npm run test:e2e:smoke-extended",
    "test:e2e:flows-smoke": "node scripts/e2e-smoke-flows.mjs",
    "test:e2e:smoke-required": "E2E_SMOKE_SUITE=required node scripts/e2e-smoke-flows.mjs",
    "test:e2e:smoke-extended": "E2E_SMOKE_SUITE=extended node scripts/e2e-smoke-flows.mjs",
    "report:any-usage": "node scripts/report-any-usage.mjs",
    "report:any-usage:total": "node scripts/report-any-usage.mjs --total-only",
    "report:any-usage:clusters": "node scripts/report-any-usage.mjs --cluster-summary",
    "report:any-usage:files": "node scripts/report-any-usage.mjs --file-summary",
    "report:any-usage:json": "node scripts/report-any-usage.mjs --json",
    "report:any-delta:pr": "node scripts/report-any-usage.mjs --total-only",
    "lint:cached": "eslint . --cache --cache-location .eslintcache --report-unused-disable-directives",
    "typecheck:batch-governed:parallel": "node scripts/run-typecheck-batches.mjs",
    "typecheck:strict-all:parallel": "npm run typecheck:baseline-global && npm run typecheck:batch-governed:parallel && npm run typecheck:legacy-exceptions",
    "check:type-safety-delta": "node scripts/check-type-safety-delta.mjs",
    "ci:any-gate": "npm run report:any-usage:total && npm run check:type-safety-delta",
    "report:any-usage:classify": "node scripts/classify-any-usage.mjs",
    "mobile:start": "npm --prefix apps/mobile run start",
    "mobile:android": "npm --prefix apps/mobile run android",
    "mobile:ios": "npm --prefix apps/mobile run ios",
    "mobile:typecheck": "npm --prefix apps/mobile run typecheck"
  },
