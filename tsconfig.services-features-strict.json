{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "strict": false,
    "strictNullChecks": true,
    "noImplicitAny": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": [
    "src/services/**/*.ts",
    "src/services/**/*.tsx",
    "src/features/**/*.ts",
    "src/features/**/*.tsx"
  ]
}
